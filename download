                return <tr key={m.id} style={{borderBottom:`1px solid ${C.gray100}`,background:i%2===0?C.white:C.gray50}}>
                  <td style={{padding:"7px 14px",fontSize:11,whiteSpace:"nowrap"}}>{D(m.date)}</td>
                  <td style={{padding:"7px 14px",fontWeight:600,fontSize:11,whiteSpace:"nowrap"}}>{prod?.name||"—"}</td>
                  <td style={{padding:"7px 14px",fontSize:10,fontFamily:"monospace",color:C.gray400}}>{prod?.codeSAP||"—"}</td>
                  <td style={{padding:"7px 14px"}}>
                    <span style={{background:isSaida?C.redAlertLight:C.greenLight,color:isSaida?C.redAlert:C.green,
                      padding:"1px 7px",borderRadius:20,fontSize:10,fontWeight:700}}>
                      {m.tmov} {isSaida?"↓":"↑"}
                    </span>
                  </td>
                  <td style={{padding:"7px 14px",fontWeight:700,fontSize:11,color:isSaida?C.redAlert:C.green,textAlign:"right"}}>
                    {isSaida?"-":"+"}{N(Math.abs(m.qty))} KG
                  </td>
                  <td style={{padding:"7px 14px",fontSize:11,color:C.gray400}}>{m.dep}</td>
                  <td style={{padding:"7px 14px",fontSize:10,fontFamily:"monospace",color:C.gray400}}>{m.doc}</td>
                  <td style={{padding:"7px 14px",fontSize:11,color:C.gray400}}>{m.obs||"—"}</td>
                </tr>;
              })}
            </tbody>
          </table>
          </div>
          {filtMovs.length>200&&<div style={{padding:"7px 14px",textAlign:"center",fontSize:11,color:C.gray400,background:C.gray50}}>Mostrando 200 de {filtMovs.length} · Use o filtro para refinar</div>}
        </div>
      </div>}

      {/* ══ IMPORTAR SAP ══ */}
      {tab==="Importar SAP"&&<ImportSAP products={products} onImport={handleImport}/>}

      {/* ══ ALERTAS ══ */}
      {tab==="Alertas"&&<div>
        <div style={{marginBottom:16}}>
          <div style={{fontSize:20,fontWeight:800}}>Central de Alertas</div>
          <div style={{fontSize:11,color:C.gray400,marginTop:2}}>{alerts.length} alertas · Posição 01/05/2026</div>
        </div>
        {alerts.length===0&&<div style={{background:C.greenLight,borderRadius:12,padding:32,textAlign:"center",color:C.green,fontWeight:700,fontSize:14}}>✓ Nenhum alerta. Todos os estoques estão adequados!</div>}
        <div style={{display:"flex",flexDirection:"column",gap:8,marginBottom:20}}>
          {alerts.map((a,i)=><div key={i} style={{background:C.white,borderRadius:11,padding:"11px 14px",boxShadow:"0 1px 4px rgba(0,0,0,0.06)",
            borderLeft:`4px solid ${a.sev==="critical"?C.red:C.yellow}`,display:"flex",alignItems:"center",gap:12}}>
            <div style={{color:a.sev==="critical"?C.red:C.yellow,fontSize:17}}>{a.sev==="critical"?"✕":"⚠"}</div>
            <div style={{flex:1}}>
              <div style={{fontWeight:700,fontSize:13}}>{a.product}</div>
              <div style={{fontSize:11,color:C.gray600,marginTop:1}}>{a.msg} · <span style={{fontFamily:"monospace",fontSize:10}}>{a.cod}</span></div>
            </div>
            <span style={{background:a.sev==="critical"?C.redAlertLight:C.yellowLight,color:a.sev==="critical"?C.red:C.yellow,padding:"2px 8px",borderRadius:20,fontSize:10,fontWeight:700}}>
              {a.sev==="critical"?"CRÍTICO":"ATENÇÃO"}
            </span>
          </div>)}
        </div>
        <div style={{background:C.white,borderRadius:12,boxShadow:"0 1px 4px rgba(0,0,0,0.06)",overflow:"hidden"}}>
          <div style={{padding:"11px 16px",borderBottom:`1px solid ${C.gray100}`}}><div style={{fontWeight:700,fontSize:14}}>Log de Auditoria</div></div>
          {logs.map((l,i)=><div key={l.id} style={{padding:"8px 16px",borderBottom:`1px solid ${C.gray100}`,display:"flex",gap:10,alignItems:"center",background:i%2===0?C.white:C.gray50}}>
            <div style={{width:26,height:26,background:C.redLight,borderRadius:6,display:"flex",alignItems:"center",justifyContent:"center",color:C.red,fontSize:11,fontWeight:700,flexShrink:0}}>{l.user[0].toUpperCase()}</div>
            <div style={{flex:1}}>
              <div style={{fontSize:12,fontWeight:600}}>{l.action}</div>
              <div style={{fontSize:10,color:C.gray400,marginTop:1}}>por <b>{l.user}</b></div>
            </div>
            <div style={{fontSize:10,color:C.gray400,flexShrink:0,whiteSpace:"nowrap"}}>{l.date}</div>
          </div>)}
        </div>
      </div>}

      {/* ══ RELATÓRIOS ══ */}
      {tab==="Relatórios"&&<div>
        <div style={{marginBottom:16}}>
          <div style={{fontSize:20,fontWeight:800}}>Relatórios e Análises</div>
          <div style={{fontSize:11,color:C.gray400}}>Jan–Mai 2026 · {PERIODO_DIAS} dias · Centro C201 · Refinaria de Manaus S.A.</div>
        </div>

        {/* Balanço */}
        <div style={{background:C.white,borderRadius:12,boxShadow:"0 1px 4px rgba(0,0,0,0.06)",overflow:"hidden",marginBottom:12}}>
          <div style={{padding:"11px 16px",borderBottom:`1px solid ${C.gray100}`}}>
            <div style={{fontWeight:700,fontSize:14}}>Balanço de Estoque — MB5B SAP</div>
            <div style={{fontSize:10,color:C.gray400,marginTop:1}}>Consumo = (EstInicial + Entradas) − EstFinal = TotalSaídas ÷ {PERIODO_DIAS} dias</div>
          </div>
          <div style={{overflowX:"auto"}}>
          <table style={{width:"100%",borderCollapse:"collapse"}}>
            <thead><tr style={{background:C.gray50}}>
              {["Produto","Cód. SAP","Est. Inicial","+ Entradas","− Saídas","= Saldo SAP","Cons./dia","Cons./mês","Cobertura","Compra Sug."].map(h=><th key={h} style={TH}>{h}</th>)}
            </tr></thead>
            <tbody>
              {[...analytics].sort((a,b)=>a.cobertura-b.cobertura).map((p,i)=><tr key={p.id} style={{borderBottom:`1px solid ${C.gray100}`,background:i%2===0?C.white:C.gray50}}>
                <td style={{padding:"8px 14px",fontWeight:600,fontSize:11,whiteSpace:"nowrap"}}>{p.name}</td>
                <td style={{padding:"8px 14px",fontSize:10,fontFamily:"monospace",color:C.gray400}}>{p.codeSAP}</td>
                <td style={{padding:"8px 14px",fontSize:11,textAlign:"right",color:C.gray600}}>0</td>
                <td style={{padding:"8px 14px",fontSize:11,textAlign:"right",color:C.green,fontWeight:600}}>+{N(p.totEnt,0)}</td>
                <td style={{padding:"8px 14px",fontSize:11,textAlign:"right",color:C.redAlert,fontWeight:600}}>−{N(p.totSai,0)}</td>
                <td style={{padding:"8px 14px",fontSize:12,textAlign:"right",fontWeight:800}}>{N(p.estAtual,0)}</td>
                <td style={{padding:"8px 14px",fontSize:11,textAlign:"right",fontWeight:700,color:C.red}}>{N(p.consDia,2)}</td>
                <td style={{padding:"8px 14px",fontSize:11,textAlign:"right",color:C.gray600}}>{N(p.consMes,0)}</td>
                <td style={{padding:"8px 14px"}}><Badge days={p.cobertura}/></td>
                <td style={{padding:"8px 14px",fontSize:11,textAlign:"right",fontWeight:700,color:p.compra>0?C.red:C.gray300}}>
                  {p.compra>0?`${N(p.compra,0)} KG`:"—"}
                </td>
              </tr>)}
            </tbody>
          </table>
          </div>
        </div>

        {/* Ranking consumo */}
        <div style={{background:C.white,borderRadius:12,boxShadow:"0 1px 4px rgba(0,0,0,0.06)",padding:18,marginBottom:12}}>
          <div style={{fontWeight:700,fontSize:14,marginBottom:12}}>Ranking de Consumo — Jan a Mai 2026 (Total MB5B)</div>
          {[...analytics].sort((a,b)=>b.totSai-a.totSai).map(p=><div key={p.id} style={{marginBottom:10}}>
            <div style={{display:"flex",justifyContent:"space-between",alignItems:"center",marginBottom:3}}>
              <span style={{fontSize:11,fontWeight:600,flex:1,whiteSpace:"nowrap",marginRight:10}}>{p.name}</span>
              <div style={{display:"flex",gap:12,alignItems:"center",flexShrink:0}}>
                <span style={{fontSize:10,color:C.gray400}}>Ent: {N(p.totEnt,0)}</span>
                <span style={{fontSize:11,fontWeight:700,color:C.red}}>Saí: {N(p.totSai,0)} KG</span>
                <span style={{fontSize:10,color:C.gray500,width:80,textAlign:"right"}}>{N(p.consDia,2)} KG/d</span>
              </div>
            </div>
            <Bar v={p.totSai} max={maxSai} color={C.red} h={7}/>
          </div>)}
        </div>

        {/* Plano de compras */}
        <div style={{background:C.white,borderRadius:12,boxShadow:"0 1px 4px rgba(0,0,0,0.06)",overflow:"hidden",marginBottom:12}}>
          <div style={{padding:"11px 16px",borderBottom:`1px solid ${C.gray100}`}}>
            <div style={{fontWeight:700,fontSize:14}}>Plano de Compras — Meta: 60 dias de cobertura</div>
            <div style={{fontSize:10,color:C.gray400,marginTop:1}}>Compra Sugerida = Cons/dia × (60 + Lead Time) − Saldo Atual</div>
          </div>
          {[...analytics].filter(p=>p.compra>0).sort((a,b)=>a.cobertura-b.cobertura).map(p=><div key={p.id} style={{padding:"10px 16px",borderBottom:`1px solid ${C.gray100}`,display:"flex",justifyContent:"space-between",alignItems:"center"}}>
            <div style={{flex:1}}>
              <div style={{fontWeight:600,fontSize:13}}>{p.name}</div>
              <div style={{fontSize:10,color:C.gray400,marginTop:2}}>
                SAP: {p.codeSAP} · LT: {p.leadTime}d · Saldo: {N(p.estAtual,0)} KG · Cons/dia: {N(p.consDia,2)} KG · Cob: {p.cobertura===9999?"∞":p.cobertura+"d"}
              </div>
            </div>
            <div style={{textAlign:"right",flexShrink:0,marginLeft:16}}>
              <div style={{fontWeight:800,fontSize:15,color:C.red}}>{N(p.compra,0)} KG</div>
              <Badge days={p.cobertura}/>
            </div>
          </div>)}
          {analytics.filter(p=>p.compra>0).length===0&&<div style={{padding:18,textAlign:"center",color:C.gray400,fontSize:12}}>✓ Todos com cobertura ≥ 60 dias</div>}
        </div>

        <div style={{display:"flex",gap:8}}>
          <button style={{...btnP,fontSize:12}} onClick={()=>alert("Para exportar: integre SheetJS (já disponível na aba Importar SAP)")}>⬇ Exportar Excel</button>
          <button style={{...btnS,fontSize:12}} onClick={()=>alert("Para PDF: adicione pdfmake via npm ao projeto")}>⬇ Exportar PDF</button>
        </div>
      </div>}

    </main>

    <footer style={{borderTop:`1px solid ${C.gray200}`,padding:"10px 20px",display:"flex",justifyContent:"space-between",alignItems:"center",background:C.white,marginTop:20}}>
      <div style={{fontSize:10,color:C.gray400}}>CHEMTRACK · Refinaria de Manaus S.A. · Centro C201 · Cons/dia = Saídas SAP ÷ {PERIODO_DIAS}d</div>
      <div style={{display:"flex",gap:10,alignItems:"center"}}>
        <div style={{fontSize:10,color:C.gray400}}>{products.length} produtos · {movements.length} movimentos</div>
        <div style={{width:5,height:5,borderRadius:"50%",background:C.green}}/>
        <div style={{fontSize:10,color:C.green,fontWeight:700}}>Online</div>
      </div>
    </footer>
  </div>;
}
