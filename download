            {l:"Saldo SAP",v:`${fmtN(prodDetails.estAtual)} KG`,c:C.red},
            {l:"Cons./dia (média)",v:`${fmtN(prodDetails.consDia,2)} KG`,c:C.gray900},
            {l:"Cobertura",v:prodDetails.cobertura===9999?"∞":`${prodDetails.cobertura} dias`,c:prodDetails.cobertura<30?C.redAlert:prodDetails.cobertura<60?C.yellow:C.green},
