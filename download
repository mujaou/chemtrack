            {l:"Total Saídas SAP",v:`${fmtN(prodDetails.totalSaidas)} KG`,c:C.red},
            {l:"Compra Sugerida",v:prodDetails.compraSugerida>0?`${fmtN(prodDetails.compraSugerida,0)} KG`:"—",c:prodDetails.compraSugerida>0?C.red:C.green},
