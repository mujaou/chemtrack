/* ══════════════════════════════════════════════
   IMPORTAR SAP — suporta múltiplos arquivos
   Detecta automaticamente: MB5B, MB51, Extrato
══════════════════════════════════════════════ */
function ImportSAP({products, onImport}){
  const [files, setFiles] = useState([]);   // [{name, rows, headers, format}]
  const [step, setStep] = useState("drop"); // drop | review | done
  const [result, setResult] = useState(null);
  const [loading, setLoading] = useState(false);
  const fileRef = useRef();

  const safeFloat = v => {
    if(v==null) return 0;
    const s = String(v).trim();
    // Float puro (ex: 539959.18)
    if(/^-?\d+\.\d+$/.test(s)) return parseFloat(s);
    // Formato BR: pontos=milhar, vírgula=decimal
    return parseFloat(s.replace(/\./g,"").replace(",",".")) || 0;
  };

  const toDateStr = v => {
    if(!v) return null;
    if(typeof v==="number"&&v>1000){
      const d=new Date((v-25569)*86400000);
      return d.toISOString().slice(0,10);
    }
    if(v instanceof Date) return v.toISOString().slice(0,10);
    if(typeof v==="string"){
      const s=v.trim();
      // DD.MM.YYYY
      const m1=s.match(/^(\d{2})\.(\d{2})\.(\d{4})$/);
      if(m1) return `${m1[3]}-${m1[2]}-${m1[1]}`;
      // YYYY-MM-DD
      if(/^\d{4}-\d{2}-\d{2}/.test(s)) return s.slice(0,10);
    }
    return null;
  };

  /* Detecta o formato e extrai registros de qualquer planilha SAP */
  const parseSheet = (data, filename) => {
    // Encontra linha de cabeçalho
    let hi = 0;
    for(let i=0;i<Math.min(8,data.length);i++){
      if(data[i].filter(c=>c!=="&&"&&c!==null&&c!=="").length > 3){hi=i;break;}
    }
    const headers = data[hi].map(h=>String(h||"").trim().toLowerCase());
    const rows = data.slice(hi+1);

    // Detectar formato
    const isMB5B  = headers.some(h=>h.includes("estoque final")||h.includes("totais qtds"));
    const isMB51  = headers.some(h=>h.includes("tipo de movimento")||h.includes("txt.tipo"));
    const isExtrato = !isMB5B && !isMB51 && headers.some(h=>h.includes("tmv")||h.includes("doc.mat"));

    const records = [];

    if(isMB5B){
      // Formato: Centro Mat DataDe DataAte EstIni TotEnt TotSai EstFin UMB Nome
      const iMat=1, iDataDe=2, iDataAte=3, iEstIni=4, iTotEnt=5, iTotSai=6, iEstFin=7, iUMB=8, iNome=9;
      rows.forEach(r=>{
        const mat=String(r[iMat]||"").trim();
        if(!mat||!/^\d{6,}$/.test(mat)) return;
        const dIni=toDateStr(r[iDataDe])||"2026-01-01";
        const dFim=toDateStr(r[iDataAte])||"2026-05-01";
        const dias=Math.max(1,Math.round((new Date(dFim)-new Date(dIni))/(864e5)));
        const totEnt=safeFloat(r[iTotEnt]);
        const totSai=Math.abs(safeFloat(r[iTotSai]));
        const estFin=safeFloat(r[iEstFin]);
        const nome=String(r[iNome]||"").trim();
        records.push({format:"MB5B",mat,nome,dIni,dFim,dias,totEnt,totSai,estFin,consDia:totSai/dias});
      });
    }
    else if(isMB51){
      // Formato: Centro Dep Mat Nome TipoAval TipoMov ... DtLcto Qtd UM ...
      const iDep=1,iMat=2,iNome=3,iTMov=5,iDtLcto=14,iQtd=15;
      rows.forEach(r=>{
        const mat=String(r[iMat]||"").trim();
        if(!mat||!/^\d{6,}$/.test(mat)) return;
        const tmov=String(r[iTMov]||"").trim();
        const dep=String(r[iDep]||"").trim();
        const nome=String(r[iNome]||"").trim();
        const date=toDateStr(r[iDtLcto]);
        const qty=safeFloat(r[iQtd]);
        if(!date||qty===0) return;
        records.push({format:"MB51",mat,nome,dep,tmov,date,qty});
      });
    }
    else if(isExtrato){
      // Extrato por material — identifica linhas de produto e linhas de movimento
      let curMat="",curNome="";
      rows.forEach(r=>{
        const c1=String(r[1]||"").trim();
        const c8=String(r[8]||"").trim();
        const c2=String(r[2]||"").trim();
        // Linha de produto
        if(/^\d{7,}$/.test(c1)&&c8&&!c8.startsWith(" ".repeat(15))){
          curMat=c1; curNome=c8; return;
        }
        // Linha de movimento
        if(curMat&&/^\d{3}$/.test(c2)){
          const dep=c1,tmov=c2,doc=String(r[4]||"").trim();
          const date=toDateStr(r[6]);
          const qty=safeFloat(r[7]);
          if(date&&qty!==0)
            records.push({format:"Extrato",mat:curMat,nome:curNome,dep,tmov,date,qty});
        }
      });
    }
    return {name:filename, format:isMB5B?"MB5B":isMB51?"MB51":"Extrato", records, count:records.length};
  };

  const handleFiles = useCallback(fileList => {
    setLoading(true);
    loadXLSX(()=>{
      const results = [];
      let done = 0;
      Array.from(fileList).forEach(file=>{
        const reader = new FileReader();
        reader.onload = e => {
          const wb = window.XLSX.read(e.target.result,{type:"array"});
          const ws = wb.Sheets[wb.SheetNames[0]];
          const data = window.XLSX.utils.sheet_to_json(ws,{header:1,raw:true,defval:""});
          results.push(parseSheet(data,file.name));
          done++;
          if(done===fileList.length){
            setFiles(results);
            setStep("review");
            setLoading(false);
          }
        };
        reader.readAsArrayBuffer(file);
      });
    });
  },[]);

  const doImport = () => {
    setLoading(true);
    const newMovs=[], newProds=[], tempMap={};
    let updatedProducts=[...products];

    files.forEach(f=>{
      f.records.forEach((rec,i)=>{
        const prod = updatedProducts.find(p=>p.codeSAP===rec.mat)||products.find(p=>p.codeSAP===rec.mat);

        if(rec.format==="MB5B"){
          // Atualiza ou cria produto com dados MB5B
          if(!prod&&!tempMap[rec.mat]){
            const np={id:Date.now()+i,codeSAP:rec.mat,name:rec.nome.toUpperCase(),unit:"KG",type:"sólido",
                      supplier:"",leadTime:15,criticality:"Média",
                      totEnt:rec.totEnt,totSai:rec.totSai,estFin:rec.estFin,consDia:rec.consDia};
            newProds.push(np); tempMap[rec.mat]=np.id;
          }
        }
        else if(rec.format==="MB51"||rec.format==="Extrato"){
          const isSaida=["201","261"].includes(rec.tmov)&&rec.qty<0;
          const isEntrada=["101"].includes(rec.tmov)&&rec.qty>0;
          if(!isSaida&&!isEntrada) return;
          let pid = prod?.id || tempMap[rec.mat];
          if(!pid){
            const np={id:Date.now()+i+5000,codeSAP:rec.mat,name:rec.nome.toUpperCase(),unit:"KG",
                      type:"sólido",supplier:"",leadTime:15,criticality:"Média",
                      totEnt:0,totSai:0,estFin:0,consDia:0};
            newProds.push(np); tempMap[rec.mat]=np.id; pid=np.id;
          }
          newMovs.push({id:Date.now()+i+9000,pid,date:rec.date,tmov:rec.tmov,
                        qty:rec.qty,dep:rec.dep||"BQ3",doc:"IMPORT",obs:`Importado: ${f.name}`});
        }
      });
    });

    setTimeout(()=>{
      onImport(newMovs,newProds,files.map(f=>f.name).join(", "));
      setResult({movs:newMovs.length,prods:newProds.length,files:files.length});
      setLoading(false); setStep("done");
    },600);
  };

  const totalRecs = files.reduce((s,f)=>s+f.count,0);

  return <div>
    <div style={{marginBottom:20}}>
      <div style={{fontSize:20,fontWeight:800}}>Importar Relatórios SAP</div>
      <div style={{fontSize:11,color:C.gray400,marginTop:2}}>
        Suporta <b>múltiplos arquivos simultâneos</b> · MB5B · MB51 · Extrato — detecção automática de formato
      </div>
    </div>

    {/* Steps */}
    <div style={{display:"flex",marginBottom:20,background:C.white,borderRadius:12,overflow:"hidden",boxShadow:"0 1px 4px rgba(0,0,0,0.06)"}}>
      {["1. Selecionar","2. Revisar","3. Concluído"].map((s,i)=>{
        const keys=["drop","review","done"];
        const act=keys[i]===step, done=keys.indexOf(step)>i;
        return <div key={s} style={{flex:1,padding:"11px 0",textAlign:"center",fontSize:12,fontWeight:act?700:500,
          color:act?C.red:done?C.green:C.gray400,
          background:act?C.redLight:done?C.greenLight:"transparent",
          borderBottom:act?`2px solid ${C.red}`:done?`2px solid ${C.green}`:`2px solid ${C.gray200}`}}>
          {done?"✓ ":""}{s}
        </div>;
      })}
    </div>

    {/* STEP 1 — Drop zone múltiplos arquivos */}
    {step==="drop"&&<div>
      <div
        onDragOver={e=>e.preventDefault()}
        onDrop={e=>{e.preventDefault();handleFiles(e.dataTransfer.files);}}
        onClick={()=>fileRef.current.click()}
        style={{border:`2px dashed ${C.gray300}`,borderRadius:16,padding:52,textAlign:"center",cursor:"pointer",background:C.gray50,transition:"border-color .2s"}}
        onMouseEnter={e=>e.currentTarget.style.borderColor=C.red}
        onMouseLeave={e=>e.currentTarget.style.borderColor=C.gray300}>
        <div style={{fontSize:44,marginBottom:10}}>📊</div>
        <div style={{fontWeight:800,fontSize:16,marginBottom:4}}>Arraste um ou mais arquivos SAP aqui</div>
        <div style={{color:C.gray400,fontSize:13,marginBottom:14}}>
          Selecione <b>múltiplos arquivos</b> de uma vez · .xlsx
        </div>
        <div style={{display:"inline-block",...btnP}}>
          {loading?"Processando...":"Selecionar arquivos"}
        </div>
        <input ref={fileRef} type="file" accept=".xlsx,.xls" multiple style={{display:"none"}}
          onChange={e=>handleFiles(e.target.files)}/>
      </div>

      <div style={{marginTop:12,display:"grid",gridTemplateColumns:"repeat(3,1fr)",gap:8}}>
        {[
          ["📋 MB5B","Resumo de saldos e totais do período — fonte de consumo médio"],
          ["📋 MB51","Movimentos detalhados por documento (tipos 201, 261, 101)"],
          ["📋 Extrato","Histórico completo por material e depósito"],
        ].map(([t,d])=><div key={t} style={{background:C.blueLight,borderRadius:10,padding:12}}>
          <div style={{fontWeight:700,fontSize:12,color:C.blue,marginBottom:3}}>{t}</div>
          <div style={{fontSize:11,color:C.blue}}>{d}</div>
        </div>)}
      </div>

      <div style={{marginTop:10,background:C.greenLight,borderRadius:10,padding:10,color:C.green,fontSize:12}}>
        <b>✓ Dados Jan–Mai 2026 já carregados:</b> {initialProducts.length} produtos · {initialMovements.length} movimentos
        · Consumo calculado: TotalSaídas MB5B ÷ {PERIODO_DIAS} dias
      </div>
    </div>}

    {/* STEP 2 — Revisão */}
    {step==="review"&&<div>
      <div style={{display:"flex",gap:10,marginBottom:14}}>
        {[
          {v:files.length,l:"arquivos",bg:C.blueLight,c:C.blue},
          {v:totalRecs,l:"registros encontrados",bg:C.greenLight,c:C.green},
          {v:files.filter(f=>f.format==="MB5B").length,l:"MB5B (resumo)",bg:C.yellowLight,c:C.yellow},
          {v:files.filter(f=>f.format==="MB51").length,l:"MB51 (movimentos)",bg:C.redAlertLight,c:C.redAlert},
        ].map(k=><div key={k.l} style={{flex:1,background:k.bg,borderRadius:10,padding:12,textAlign:"center"}}>
          <div style={{fontSize:26,fontWeight:800,color:k.c}}>{k.v}</div>
          <div style={{fontSize:11,color:k.c}}>{k.l}</div>
        </div>)}
      </div>

      {files.map((f,fi)=><div key={fi} style={{background:C.white,border:`1px solid ${C.gray200}`,borderRadius:12,overflow:"hidden",marginBottom:10}}>
        <div style={{padding:"10px 14px",background:C.gray50,borderBottom:`1px solid ${C.gray100}`,display:"flex",justifyContent:"space-between",alignItems:"center"}}>
          <div style={{fontWeight:700,fontSize:13}}>📊 {f.name}</div>
          <div style={{display:"flex",gap:8,alignItems:"center"}}>
            <span style={{background:C.blueLight,color:C.blue,padding:"2px 8px",borderRadius:20,fontSize:11,fontWeight:700}}>{f.format}</span>
            <span style={{fontSize:12,color:C.gray400}}>{f.count} registros</span>
          </div>
        </div>
        <div style={{maxHeight:180,overflowY:"auto"}}>
          <table style={{width:"100%",borderCollapse:"collapse",fontSize:11}}>
            <thead><tr style={{background:C.gray50}}>
              {f.format==="MB5B"
                ?["Material","Nome","Cons/dia","Saldo Final","Cobertura"].map(h=><th key={h} style={TH}>{h}</th>)
                :["Data","Material","Nome","Tipo Mov","Quantidade","Dep"].map(h=><th key={h} style={TH}>{h}</th>)
              }
            </tr></thead>
            <tbody>
              {f.records.slice(0,50).map((r,ri)=>{
                const prod=products.find(p=>p.codeSAP===r.mat);
                return f.format==="MB5B"
                  ?<tr key={ri} style={{borderBottom:`1px solid ${C.gray100}`}}>
                    <td style={{padding:"5px 10px",fontFamily:"monospace"}}>{r.mat}</td>
                    <td style={{padding:"5px 10px",fontWeight:500}}>{r.nome?.slice(0,28)}</td>
                    <td style={{padding:"5px 10px",textAlign:"right",fontWeight:700}}>{N(r.consDia,2)} KG/d</td>
                    <td style={{padding:"5px 10px",textAlign:"right"}}>{N(r.estFin)} KG</td>
                    <td style={{padding:"5px 10px"}}>{r.consDia>0?<Badge days={Math.round(r.estFin/r.consDia)}/>:"—"}</td>
                  </tr>
                  :<tr key={ri} style={{borderBottom:`1px solid ${C.gray100}`,background:ri%2===0?C.white:C.gray50}}>
                    <td style={{padding:"5px 10px"}}>{D(r.date)}</td>
                    <td style={{padding:"5px 10px",fontFamily:"monospace"}}>{r.mat}</td>
                    <td style={{padding:"5px 10px"}}>{(r.nome||prod?.name||"").slice(0,22)}</td>
                    <td style={{padding:"5px 10px"}}>
                      <span style={{background:["201","261"].includes(r.tmov)?C.redAlertLight:C.greenLight,
                        color:["201","261"].includes(r.tmov)?C.redAlert:C.green,
                        padding:"1px 6px",borderRadius:20,fontSize:10,fontWeight:700}}>{r.tmov}</span>
                    </td>
                    <td style={{padding:"5px 10px",fontWeight:700,textAlign:"right",
                      color:r.qty<0?C.redAlert:C.green}}>{r.qty<0?"-":"+"}{N(Math.abs(r.qty))} KG</td>
                    <td style={{padding:"5px 10px",color:C.gray400}}>{r.dep}</td>
                  </tr>;
              })}
            </tbody>
          </table>
          {f.records.length>50&&<div style={{padding:"6px 12px",fontSize:11,color:C.gray400}}>+{f.records.length-50} registros...</div>}
        </div>
      </div>)}

      <div style={{display:"flex",gap:8,justifyContent:"flex-end",marginTop:4}}>
        <button style={btnS} onClick={()=>{setStep("drop");setFiles([]);}}>← Voltar</button>
        <button style={{...btnP,opacity:loading?0.7:1}} onClick={doImport} disabled={loading}>
          {loading?"Importando...":"✓ Confirmar Importação"}
        </button>
      </div>
    </div>}

    {/* STEP 3 — Concluído */}
    {step==="done"&&result&&<div style={{textAlign:"center",padding:40}}>
      <div style={{fontSize:52,marginBottom:12}}>✅</div>
      <div style={{fontSize:20,fontWeight:800,marginBottom:6}}>Importação Concluída!</div>
      <div style={{color:C.gray400,fontSize:12,marginBottom:22}}>{result.files} arquivo(s) processados</div>
      <div style={{display:"flex",gap:12,justifyContent:"center",marginBottom:28}}>
        <div style={{background:C.blueLight,borderRadius:12,padding:"14px 22px"}}><div style={{fontSize:26,fontWeight:800,color:C.blue}}>{result.files}</div><div style={{fontSize:11,color:C.blue}}>arquivos</div></div>
        <div style={{background:C.greenLight,borderRadius:12,padding:"14px 22px"}}><div style={{fontSize:26,fontWeight:800,color:C.green}}>{result.movs}</div><div style={{fontSize:11,color:C.green}}>movimentos</div></div>
        {result.prods>0&&<div style={{background:C.yellowLight,borderRadius:12,padding:"14px 22px"}}><div style={{fontSize:26,fontWeight:800,color:C.yellow}}>{result.prods}</div><div style={{fontSize:11,color:C.yellow}}>novos produtos</div></div>}
      </div>
      <div style={{display:"flex",gap:8,justifyContent:"center"}}>
        <button style={btnS} onClick={()=>{setStep("drop");setFiles([]);setResult(null);}}>+ Importar mais arquivos</button>
      </div>
    </div>}
  </div>;
}

/* ═══════════════════════════ APP PRINCIPAL ═══════════════════════════ */
export default function App(){
  const[tab,setTab]=useState("Dashboard");
  const[products,setProducts]=useState(initialProducts);
  const[movements,setMovements]=useState(initialMovements);
  const[showAddProd,setShowAddProd]=useState(false);
  const[showAddMov,setShowAddMov]=useState(false);
  const[detailProd,setDetailProd]=useState(null);
  const[newProd,setNewProd]=useState({codeSAP:"",name:"",unit:"KG",type:"sólido",supplier:"",leadTime:15,criticality:"Média"});
  const[newMov,setNewMov]=useState({pid:"",date:new Date().toISOString().slice(0,10),tmov:"201",qty:"",dep:"BQ3",obs:""});
  const[filterMov,setFilterMov]=useState("");
  const[logs,setLogs]=useState([{id:1,user:"sistema",action:`Dados SAP carregados — MB5B + MB51 · ${initialProducts.length} produtos · ${PERIODO_DIAS} dias (01/01–01/05/2026)`,date:"01/05/2026 00:00"}]);

  const addLog=a=>setLogs(l=>[{id:Date.now(),user:"operador",action:a,date:new Date().toLocaleString("pt-BR")},...l]);

  /* ══ ANALYTICS — fórmula correta ══
     Para cada produto:
     • consDia  = p.totSai / PERIODO_DIAS  (fonte MB5B, mais confiável)
     • estAtual = p.estFin  (saldo SAP em 01/05/2026)
     • consumo mensal = MB51 real quando disponível, estimativa proporcional para os demais
     • Após importações adicionais: reconsidera os novos movimentos
  */
  const analytics = useMemo(()=>products.map(p=>{
    const movsProd = movements.filter(m=>m.pid===p.id).sort((a,b)=>a.date.localeCompare(b.date));

    // Consumo base: usa consDia do produto (MB5B) se disponível
    // Para produtos importados sem MB5B, calcula dos movimentos
    let consDia = p.consDia||0;
    let estAtual = p.estFin||0;
    let totSai   = p.totSai||0;
    let totEnt   = p.totEnt||0;

    if(!p.consDia&&movsProd.length>0){
      // Produto novo importado — calcula dos movimentos
      const saidas = movsProd.filter(m=>["201","261"].includes(m.tmov)&&m.qty<0);
      const ents   = movsProd.filter(m=>["101"].includes(m.tmov)&&m.qty>0);
      totSai = saidas.reduce((s,m)=>s+Math.abs(m.qty),0);
      totEnt = ents.reduce((s,m)=>s+m.qty,0);
      const datas  = movsProd.map(m=>m.date).sort();
      const d0=new Date(datas[0]||"2026-01-01"), d1=new Date("2026-05-01");
      const dias   = Math.max(1,Math.round((d1-d0)/864e5));
      consDia = totSai/dias;
      estAtual= totEnt - totSai; // estimativa
    }

    const consMes = consDia*30;
    const cobertura = consDia>0?Math.round(estAtual/consDia):9999;
    const estMin    = consDia*60;
    const pontoPedido = consDia*p.leadTime;
    const compra    = Math.max(0, consDia*(60+p.leadTime)-estAtual);

    // Consumo mensal
    const byMonth = calcMensal(p.codeSAP, consDia);

    return {...p,movsProd,consDia,consMes,estAtual,totSai,totEnt,cobertura,estMin,pontoPedido,compra,byMonth};
  }),[products,movements]);

  const sorted = useMemo(()=>[...analytics].sort((a,b)=>a.cobertura-b.cobertura),[analytics]);

  const kpis = useMemo(()=>({
    total:analytics.length,
    crit:analytics.filter(p=>p.cobertura<30).length,
    attn:analytics.filter(p=>p.cobertura>=30&&p.cobertura<60).length,
    ok:analytics.filter(p=>p.cobertura>=60||p.cobertura===9999).length,
    movs:movements.length,
  }),[analytics,movements]);

  const alerts = useMemo(()=>{
    const a=[];
    analytics.forEach(p=>{
      if(p.estAtual===0&&p.consDia>0) a.push({sev:"critical",product:p.name,cod:p.codeSAP,msg:"Estoque zerado — ruptura imediata"});
      else if(p.cobertura<30&&p.cobertura!==9999) a.push({sev:"critical",product:p.name,cod:p.codeSAP,msg:`Cobertura crítica: ${p.cobertura} dias`});
      else if(p.cobertura<60&&p.cobertura!==9999) a.push({sev:"warning",product:p.name,cod:p.codeSAP,msg:`Atenção: ${p.cobertura} dias de cobertura`});
      if(p.estAtual>0&&p.estAtual<=p.pontoPedido&&p.pontoPedido>0) a.push({sev:"warning",product:p.name,cod:p.codeSAP,msg:`Abaixo do ponto de pedido (${N(p.pontoPedido,0)} KG)`});
    });
    return a.sort((a,b)=>(a.sev==="critical"?0:1)-(b.sev==="critical"?0:1));
  },[analytics]);

  function handleImport(newMovs,newProds,fname){
    if(newMovs.length) setMovements(m=>[...m,...newMovs]);
    if(newProds.length) setProducts(p=>[...p,...newProds]);
    addLog(`Importou ${newMovs.length} movimentos · ${newProds.length} novos produtos · Arquivo(s): ${fname}`);
  }

  function handleAddProd(e){
    e.preventDefault();
    const p={...newProd,id:Date.now(),leadTime:+newProd.leadTime,totEnt:0,totSai:0,estFin:0,consDia:0};
    setProducts(pr=>[...pr,p]); addLog(`Cadastrou ${p.codeSAP} – ${p.name}`);
    setNewProd({codeSAP:"",name:"",unit:"KG",type:"sólido",supplier:"",leadTime:15,criticality:"Média"});
    setShowAddProd(false);
  }

  function handleAddMov(e){
    e.preventDefault();
    const isSaida=["201","261"].includes(newMov.tmov);
    const m={...newMov,id:Date.now(),pid:+newMov.pid,qty:isSaida?-Math.abs(+newMov.qty):Math.abs(+newMov.qty),doc:"MANUAL"};
    setMovements(mv=>[...mv,m]);
    const pName=products.find(p=>p.id===m.pid)?.name??"";
    addLog(`${isSaida?"Saída":"Entrada"} manual (${m.tmov}): ${N(Math.abs(m.qty))} KG — ${pName}`);
    setNewMov({pid:"",date:new Date().toISOString().slice(0,10),tmov:"201",qty:"",dep:"BQ3",obs:""});
    setShowAddMov(false);
  }

  const filtMovs=useMemo(()=>{
    const mv=[...movements].sort((a,b)=>b.date.localeCompare(a.date));
    if(!filterMov) return mv;
    const ids=products.filter(p=>p.name.toLowerCase().includes(filterMov.toLowerCase())||p.codeSAP.includes(filterMov)).map(p=>p.id);
    return mv.filter(m=>ids.includes(m.pid));
  },[movements,products,filterMov]);

  const maxEst = Math.max(...analytics.map(p=>p.estAtual),1);
  const maxSai = Math.max(...analytics.map(p=>p.totSai),1);

  const cobColor = d => d<30?C.redAlert:d<60?C.yellow:C.green;

  return <div style={{minHeight:"100vh",background:C.gray50,fontFamily:"'IBM Plex Sans','Helvetica Neue',Arial,sans-serif",color:C.gray900}}>

    {/* HEADER */}
    <header style={{background:C.red,color:C.white,padding:"0 20px",display:"flex",alignItems:"center",gap:12,height:56,boxShadow:"0 2px 16px rgba(200,16,46,0.22)",position:"sticky",top:0,zIndex:100}}>
      <div style={{display:"flex",alignItems:"center",gap:9,minWidth:170}}>
        <div style={{width:32,height:32,background:"rgba(255,255,255,0.15)",borderRadius:7,display:"flex",alignItems:"center",justifyContent:"center",fontSize:16,fontWeight:900}}>⬡</div>
