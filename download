          <div style={{fontSize:11,color:C.gray400,marginTop:2}}>{alerts.length} alertas ativos · posição 01/05/2026</div>
        </div>
        {alerts.length===0&&<div style={{background:C.greenLight,borderRadius:12,padding:32,textAlign:"center",color:C.green,fontWeight:700,fontSize:14}}>✓ Nenhum alerta. Todos os estoques adequados!</div>}
        <div style={{display:"flex",flexDirection:"column",gap:9,marginBottom:22}}>
          {alerts.map((a,i)=><div key={i} style={{background:C.white,borderRadius:12,padding:"12px 16px",boxShadow:"0 1px 4px rgba(0,0,0,0.06)",borderLeft:`4px solid ${a.sev==="critical"?C.red:C.yellow}`,display:"flex",alignItems:"center",gap:12}}>
            <div style={{color:a.sev==="critical"?C.red:C.yellow,fontSize:18}}>{a.sev==="critical"?"✕":"⚠"}</div>
            <div style={{flex:1}}>
              <div style={{fontWeight:700,fontSize:13}}>{a.product}</div>
              <div style={{fontSize:12,color:C.gray600,marginTop:1}}>{a.msg} · <span style={{fontFamily:"monospace",fontSize:10}}>{a.cod}</span></div>
            </div>
            <span style={{background:a.sev==="critical"?C.redAlertLight:C.yellowLight,color:a.sev==="critical"?C.red:C.yellow,padding:"2px 9px",borderRadius:20,fontSize:10,fontWeight:700}}>
              {a.sev==="critical"?"CRÍTICO":"ATENÇÃO"}
            </span>
          </div>)}
        </div>
        <div style={{background:C.white,borderRadius:12,boxShadow:"0 1px 4px rgba(0,0,0,0.06)",overflow:"hidden"}}>
          <div style={{padding:"12px 18px",borderBottom:`1px solid ${C.gray100}`}}><div style={{fontWeight:700,fontSize:14}}>Log de Auditoria</div></div>
          {logs.map((l,i)=><div key={l.id} style={{padding:"9px 18px",borderBottom:`1px solid ${C.gray100}`,display:"flex",gap:10,alignItems:"center",background:i%2===0?C.white:C.gray50}}>
            <div style={{width:27,height:27,background:C.redLight,borderRadius:6,display:"flex",alignItems:"center",justifyContent:"center",color:C.red,fontSize:11,fontWeight:700,flexShrink:0}}>{l.user[0].toUpperCase()}</div>
            <div style={{flex:1}}>
              <div style={{fontSize:12,fontWeight:600}}>{l.action}</div>
              <div style={{fontSize:10,color:C.gray400,marginTop:1}}>por <b>{l.user}</b></div>
            </div>
            <div style={{fontSize:10,color:C.gray400,flexShrink:0,whiteSpace:"nowrap"}}>{l.date}</div>
          </div>)}
        </div>
      </div>}

      {/* ══ RELATÓRIOS ══ */}
      {tab==="Relatórios"&&<div>
        <div style={{marginBottom:18}}>
          <div style={{fontSize:20,fontWeight:800}}>Relatórios e Análises</div>
          <div style={{fontSize:11,color:C.gray400,marginTop:2}}>Jan–Mai 2026 · {PERIODO_DIAS} dias · Centro C201 · Refinaria de Manaus S.A.</div>
        </div>

        {/* Resumo balanço por produto */}
        <div style={{background:C.white,borderRadius:12,boxShadow:"0 1px 4px rgba(0,0,0,0.06)",overflow:"hidden",marginBottom:14}}>
          <div style={{padding:"12px 18px",borderBottom:`1px solid ${C.gray100}`}}>
            <div style={{fontWeight:700,fontSize:14}}>Balanço de Estoque por Produto — {PERIODO_DIAS} dias</div>
            <div style={{fontSize:10,color:C.gray400,marginTop:1}}>Fórmula: Consumo = (Est.Inicial + Entradas) - Est.Final · Verificado contra MB5B SAP</div>
          </div>
          <div style={{overflowX:"auto"}}><table style={{width:"100%",borderCollapse:"collapse"}}>
            <thead><tr style={{background:C.gray50}}>
              {["Produto","Est. Inicial","+ Entradas","- Saídas (Cons.)","= Saldo SAP","Cons./dia","Cons./mês","Cobertura"].map(h=><th key={h} style={TH}>{h}</th>)}
            </tr></thead>
            <tbody>
              {[...analytics].sort((a,b)=>b.totalSaidas-a.totalSaidas).map((p,i)=><tr key={p.id} style={{borderBottom:`1px solid ${C.gray100}`,background:i%2===0?C.white:C.gray50}}>
                <td style={{padding:"9px 14px",fontWeight:600,fontSize:11,whiteSpace:"nowrap"}}>{p.name}</td>
                <td style={{padding:"9px 14px",fontSize:11,textAlign:"right"}}>{fmtN(p.estIni||0)}</td>
                <td style={{padding:"9px 14px",fontSize:11,textAlign:"right",color:C.green,fontWeight:600}}>+{fmtN(p.totalEntradas)}</td>
                <td style={{padding:"9px 14px",fontSize:11,textAlign:"right",color:C.redAlert,fontWeight:600}}>-{fmtN(p.totalSaidas)}</td>
                <td style={{padding:"9px 14px",fontSize:11,textAlign:"right",fontWeight:700}}>{fmtN(p.estAtual)}</td>
                <td style={{padding:"9px 14px",fontSize:11,textAlign:"right",fontWeight:600}}>{fmtN(p.consDia,2)}</td>
                <td style={{padding:"9px 14px",fontSize:11,textAlign:"right"}}>{fmtN(p.consMes,0)}</td>
                <td style={{padding:"9px 14px"}}><StatusBadge days={p.cobertura}/></td>
              </tr>)}
            </tbody>
          </table></div>
        </div>

        {/* Consumo gráfico de barras */}
        <div style={{background:C.white,borderRadius:12,boxShadow:"0 1px 4px rgba(0,0,0,0.06)",padding:18,marginBottom:14}}>
          <div style={{fontWeight:700,fontSize:14,marginBottom:14}}>Ranking de Consumo — Total Jan–Mai 2026</div>
          {[...analytics].sort((a,b)=>b.totalSaidas-a.totalSaidas).map(p=><div key={p.id} style={{marginBottom:11}}>
            <div style={{display:"flex",justifyContent:"space-between",alignItems:"center",marginBottom:3}}>
              <span style={{fontSize:11,fontWeight:600,flex:1}}>{p.name}</span>
              <div style={{display:"flex",gap:14,alignItems:"center",flexShrink:0}}>
                <span style={{fontSize:10,color:C.gray400}}>Entradas: {fmtN(p.totalEntradas)} KG</span>
                <span style={{fontSize:11,fontWeight:700,color:C.red}}>Saídas: {fmtN(p.totalSaidas)} KG</span>
                <span style={{fontSize:10,color:C.gray400,width:70,textAlign:"right"}}>{fmtN(p.consDia,1)} KG/d</span>
              </div>
            </div>
            <Bar value={p.totalSaidas} max={maxSaidas} color={C.red} h={8}/>
          </div>)}
        </div>

        {/* Plano de compras */}
        <div style={{background:C.white,borderRadius:12,boxShadow:"0 1px 4px rgba(0,0,0,0.06)",overflow:"hidden",marginBottom:14}}>
          <div style={{padding:"12px 18px",borderBottom:`1px solid ${C.gray100}`}}>
            <div style={{fontWeight:700,fontSize:14}}>Plano de Compras — Cobertura Meta: 60 dias</div>
            <div style={{fontSize:10,color:C.gray400,marginTop:1}}>Compra = (Cons/dia × (60 + Lead Time)) − Saldo Atual</div>
          </div>
          {analytics.filter(p=>p.compraSugerida>0).length===0&&<div style={{padding:18,color:C.gray400,textAlign:"center",fontSize:12}}>✓ Todos os produtos com cobertura ≥ 60 dias</div>}
          {[...analytics].filter(p=>p.compraSugerida>0).sort((a,b)=>a.cobertura-b.cobertura).map(p=><div key={p.id} style={{padding:"11px 18px",borderBottom:`1px solid ${C.gray100}`,display:"flex",justifyContent:"space-between",alignItems:"center"}}>
            <div style={{flex:1}}>
              <div style={{fontWeight:600,fontSize:13}}>{p.name}</div>
              <div style={{fontSize:10,color:C.gray400,marginTop:2}}>
                Lead time: {p.leadTime}d · Saldo: {fmtN(p.estAtual)} KG · Cons./dia: {fmtN(p.consDia,2)} KG · Cob. atual: {p.cobertura===9999?"∞":p.cobertura+"d"}
              </div>
            </div>
            <div style={{textAlign:"right",flexShrink:0,marginLeft:16}}>
              <div style={{fontWeight:800,fontSize:15,color:C.red}}>{fmtN(p.compraSugerida,0)} KG</div>
              <StatusBadge days={p.cobertura}/>
            </div>
          </div>)}
        </div>

        <div style={{display:"flex",gap:8}}>
          <button style={{...btnP,fontSize:12}} onClick={()=>alert("Exporte com SheetJS — biblioteca já disponível na aba Importar SAP")}>⬇ Exportar Excel</button>
          <button style={{...btnS,fontSize:12}} onClick={()=>alert("Integre pdfmake para exportação em PDF")}>⬇ Exportar PDF</button>
        </div>
      </div>}

    </main>

    <footer style={{borderTop:`1px solid ${C.gray200}`,padding:"11px 22px",display:"flex",justifyContent:"space-between",alignItems:"center",background:C.white,marginTop:22}}>
      <div style={{fontSize:10,color:C.gray400}}>CHEMTRACK · Refinaria de Manaus S.A. · Centro C201 · Fórmula: Consumo = Saídas SAP (201+261) ÷ {PERIODO_DIAS} dias</div>
      <div style={{display:"flex",gap:10,alignItems:"center"}}>
        <div style={{fontSize:10,color:C.gray400}}>{products.length} produtos · {movements.length} movimentos</div>
        <div style={{width:5,height:5,borderRadius:"50%",background:C.green}}/>
        <div style={{fontSize:10,color:C.green,fontWeight:700}}>Online</div>
      </div>
    </footer>
  </div>;
}
