/* Função para calcular consumo mensal estimado quando MB51 não tem detalhes */
function calcMensal(codeSAP, consDia) {
  const mb51 = MB51_MENSAL[codeSAP];
  if (mb51) return mb51;
  // Estimativa proporcional por dias do mês
  const est = {};
  MESES.forEach(m => { est[m] = parseFloat((consDia * DIAS_MES[m]).toFixed(2)); });
  return est;
}

