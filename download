function StatusBadge({days}){
  if(days>=60||days===9999)return<span style={{background:C.greenLight,color:C.green,padding:"2px 10px",borderRadius:20,fontSize:11,fontWeight:700,whiteSpace:"nowrap"}}>● ADEQUADO</span>;
  if(days>=30)return<span style={{background:C.yellowLight,color:C.yellow,padding:"2px 10px",borderRadius:20,fontSize:11,fontWeight:700,whiteSpace:"nowrap"}}>◐ ATENÇÃO</span>;
  return<span style={{background:C.redAlertLight,color:C.redAlert,padding:"2px 10px",borderRadius:20,fontSize:11,fontWeight:700,whiteSpace:"nowrap"}}>✕ CRÍTICO</span>;
}
function CritBadge({level}){
  const m={Alta:{bg:C.redAlertLight,co:"#B91C1C"},Média:{bg:C.yellowLight,co:C.yellow},Baixa:{bg:C.greenLight,co:C.green}};
  const s=m[level]||m.Baixa;
  return<span style={{background:s.bg,color:s.co,padding:"2px 8px",borderRadius:20,fontSize:10,fontWeight:700}}>{level}</span>;
}
function Bar({value,max,color="#C8102E",h=6}){
  return<div style={{background:C.gray200,borderRadius:4,height:h,width:"100%",overflow:"hidden"}}>
    <div style={{background:color,width:`${Math.min(100,(value/(max||1))*100)}%`,height:"100%",borderRadius:4,transition:"width 0.4s"}}/>
  </div>;
}

function Modal({title,onClose,children,width=520}){
  return<div style={{position:"fixed",inset:0,background:"rgba(0,0,0,0.4)",zIndex:200,display:"flex",alignItems:"center",justifyContent:"center"}}>
    <div style={{background:C.white,borderRadius:16,padding:28,width,maxHeight:"90vh",overflowY:"auto",boxShadow:"0 8px 40px rgba(0,0,0,0.2)"}}>
      <div style={{display:"flex",justifyContent:"space-between",alignItems:"center",marginBottom:18}}>
        <div style={{fontWeight:800,fontSize:16}}>{title}</div>
        <button onClick={onClose} style={{...btnS,padding:"4px 12px",fontSize:14}}>✕</button>
      </div>
      {children}
    </div>
  </div>;
}

/* ══ IMPORTAR SAP ══ */
function ImportSAP({products,onImport}){
  const[step,setStep]=useState("upload");
  const[rawRows,setRawRows]=useState([]);
  const[headers,setHeaders]=useState([]);
  const[map,setMap]=useState({material:"",nome:"",data:"",qtd:"",tipo:""});
  const[importDate,setImportDate]=useState(new Date().toISOString().slice(0,10));
  const[preview,setPreview]=useState([]);
  const[fileName,setFileName]=useState("");
  const[loading,setLoading]=useState(false);
  const[result,setResult]=useState(null);
  const fileRef=useRef();

  const handleFile=file=>{
    if(!file)return;
    setFileName(file.name);setStep("upload");setResult(null);
    loadSheetJS(()=>{
      const r=new FileReader();
      r.onload=e=>{
        const wb=window.XLSX.read(e.target.result,{type:"array"});
        const ws=wb.Sheets[wb.SheetNames[0]];
        const data=window.XLSX.utils.sheet_to_json(ws,{header:1,raw:true,defval:""});
        let hi=0;
        for(let i=0;i<Math.min(8,data.length);i++)
          if(data[i].filter(c=>c!=="").length>3){hi=i;break;}
        const hdrs=data[hi].map(h=>String(h||"").trim());
        const rows=data.slice(hi+1).filter(r=>r.some(c=>c!==""));
        setHeaders(hdrs);setRawRows(rows);
        // auto-map
        const am={material:"",nome:"",data:"",qtd:"",tipo:""};
        hdrs.forEach((h,i)=>{
          const l=h.toLowerCase();
          if(l.includes("material")&&!l.includes("texto"))am.material=String(i);
          if(l.includes("texto breve")||l.includes("descrição"))am.nome=String(i);
          if(l.includes("lançamento")||l.includes("lçto"))am.data=String(i);
          if(l.includes("estoque final"))am.qtd=String(i);
          else if(!am.qtd&&l.includes("qtd")&&l.includes("registro"))am.qtd=String(i);
          if(l.includes("tipo de movimento")||l.includes("tmv")||l==="tmv")am.tipo=String(i);
        });
        setMap(am);setStep("map");
      };
      r.readAsArrayBuffer(file);
    });
  };

  const toDate=v=>{
    if(typeof v==="number"&&v>1000)return new Date((v-25569)*86400000).toISOString().slice(0,10);
    if(v instanceof Date)return v.toISOString().slice(0,10);
    if(typeof v==="string"&&v.includes(".")){
      const[d,m,y]=v.trim().split(".");
      if(y&&m&&d)return`${y.length===4?y:"20"+y}-${m.padStart(2,"0")}-${d.padStart(2,"0")}`;
    }
    return null;
  };

  const buildPreview=()=>{
    const parsed=[];
    rawRows.slice(0,1000).forEach(row=>{
      const matRaw=row[Number(map.material)];
      if(!matRaw)return;
      const matCode=String(matRaw).trim();
      if(!matCode||!matCode.match(/\d{5,}/))return;
      const nomeRaw=String(row[Number(map.nome)]||"").trim();
      const qtdRaw=row[Number(map.qtd)];
      const tipoRaw=map.tipo?String(row[Number(map.tipo)]||"").trim():"";
      const dataRaw=map.data?row[Number(map.data)]:importDate;
      if(qtdRaw===""||qtdRaw===null||qtdRaw===undefined)return;
      const qtd=parseFloat(String(qtdRaw).replace(/\./g,"").replace(",","."));
      if(isNaN(qtd)||qtd===0)return;
      const dateStr=toDate(dataRaw)||importDate;
      const prod=products.find(p=>p.codeSAP===matCode);
      // Classificar tipo de movimento
      let type="saida";
      if(tipoRaw===""){ type=qtd>0?"saldo":"saida"; }
      else if(["101"].includes(tipoRaw))type="entrada";
      else if(["201","261"].includes(tipoRaw))type="saida";
      else if(tipoRaw==="202")type="entrada";
      else type=qtd<0?"saida":"entrada";
      parsed.push({codeSAP:matCode,nome:nomeRaw.slice(0,40)||matCode,date:dateStr,qty:Math.abs(qtd),type,tipoMov:tipoRaw,matched:!!prod,productId:prod?.id});
    });
    setPreview(parsed);setStep("preview");
  };

  const doImport=()=>{
    setLoading(true);
    const newMovs=[];const newProds=[];const tempMap={};
    preview.forEach((row,i)=>{
      let pid=row.productId;
      if(!pid){
        if(!tempMap[row.codeSAP]){
          const np={id:Date.now()+i,name:row.nome.toUpperCase(),codeSAP:row.codeSAP,unit:"KG",type:"sólido",supplier:"",leadTime:15,criticality:"Média",estIni:0,totalEntradas:0,totalSaidas:0,estFin:0};
          newProds.push(np);tempMap[row.codeSAP]=np.id;
        }
        pid=tempMap[row.codeSAP];
      }
      newMovs.push({id:Date.now()+i+9000,pid,date:row.date,tipo:row.tipoMov||row.type,qty:row.type==="saida"?-row.qty:row.qty,dep:"BQ3",doc:"IMPORT",obs:`Importado: ${fileName}`});
    });
    setTimeout(()=>{
      onImport(newMovs,newProds,fileName);
      setResult({added:newMovs.length,newProds:newProds.length});
      setLoading(false);setStep("done");
    },600);
  };

  const steps=["upload","map","preview","done"];
  const stepLabels=["1. Arquivo","2. Colunas","3. Revisão","4. Concluído"];

  return<div>
    <div style={{marginBottom:20}}>
      <div style={{fontSize:20,fontWeight:800}}>Importar Relatório SAP</div>
      <div style={{fontSize:12,color:C.gray400,marginTop:2}}>MB51 (movimentos) · MB52/MB5B (resumo) · Qualquer extrato SAP</div>
    </div>
    {/* Stepper */}
    <div style={{display:"flex",marginBottom:22,background:C.white,borderRadius:12,overflow:"hidden",boxShadow:"0 1px 4px rgba(0,0,0,0.06)"}}>
      {stepLabels.map((s,i)=>{const act=steps[i]===step;const done=steps.indexOf(step)>i;return<div key={s} style={{flex:1,padding:"12px 0",textAlign:"center",fontSize:12,fontWeight:act?700:500,color:act?C.red:done?C.green:C.gray400,background:act?C.redLight:done?C.greenLight:"transparent",borderBottom:act?`2px solid ${C.red}`:done?`2px solid ${C.green}`:`2px solid ${C.gray200}`}}>{done?"✓ ":""}{s}</div>;})}
    </div>

    {step==="upload"&&<div>
      <div onClick={()=>fileRef.current.click()} onDragOver={e=>e.preventDefault()} onDrop={e=>{e.preventDefault();handleFile(e.dataTransfer.files[0]);}}
        style={{border:`2px dashed ${C.gray300}`,borderRadius:16,padding:52,textAlign:"center",cursor:"pointer",background:C.gray50}}>
        <div style={{fontSize:42,marginBottom:10}}>📊</div>
        <div style={{fontWeight:700,fontSize:16,marginBottom:4}}>Arraste o arquivo Excel do SAP aqui</div>
        <div style={{color:C.gray400,fontSize:13,marginBottom:14}}>ou clique para selecionar · .xlsx</div>
        <div style={{display:"inline-block",...btnP}}>Selecionar arquivo</div>
        <input ref={fileRef} type="file" accept=".xlsx,.xls" style={{display:"none"}} onChange={e=>handleFile(e.target.files[0])}/>
      </div>
      <div style={{marginTop:12,display:"grid",gridTemplateColumns:"repeat(3,1fr)",gap:8}}>
        {[["📋 MB51","Movimentos por documento (201=saída, 101=entrada)"],["📋 MB5B / MB52","Resumo por período (estoque inicial/final)"],["📋 Extrato","Histórico detalhado por material e depósito"]].map(([t,d])=><div key={t} style={{background:C.blueLight,borderRadius:10,padding:12}}><div style={{fontWeight:700,fontSize:12,color:C.blue,marginBottom:2}}>{t}</div><div style={{fontSize:11,color:C.blue}}>{d}</div></div>)}
      </div>
      <div style={{marginTop:10,background:C.greenLight,borderRadius:10,padding:10,color:C.green,fontSize:12}}>
        <b>✓ Dados Jan–Mai 2026 já carregados</b> · {initialProducts.length} produtos · {initialMovements.length} movimentos · Fonte: MB5B + MB51 SAP
      </div>
    </div>}

    {step==="map"&&<div>
      <div style={{background:C.greenLight,borderRadius:8,padding:10,marginBottom:16,fontSize:13,color:C.green}}>✓ <b>{fileName}</b> · {rawRows.length} linhas · {headers.length} colunas</div>
      <div style={{background:C.white,borderRadius:12,border:`1px solid ${C.gray200}`,padding:18,marginBottom:14}}>
        <div style={{fontWeight:700,marginBottom:12,fontSize:14}}>Mapeamento de Colunas</div>
        <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:10}}>
          {[{l:"Código SAP *",f:"material"},{l:"Nome/Descrição",f:"nome"},{l:"Data lançamento",f:"data"},{l:"Quantidade *",f:"qtd"},{l:"Tipo movimento",f:"tipo"}].map(({l,f})=><div key={f}>
            <label style={{fontSize:12,fontWeight:600,color:C.gray600,display:"block",marginBottom:3}}>{l}</label>
            <select style={inp} value={map[f]} onChange={e=>setMap(m=>({...m,[f]:e.target.value}))}>
              <option value="">— não usar —</option>
              {headers.map((h,i)=><option key={i} value={String(i)}>{h||`Col ${i+1}`}</option>)}
            </select>
          </div>)}
        </div>
        <div style={{marginTop:12}}>
          <label style={{fontSize:12,fontWeight:600,color:C.gray600,display:"block",marginBottom:3}}>Data de referência (se sem coluna de data)</label>
          <input type="date" style={{...inp,width:210}} value={importDate} onChange={e=>setImportDate(e.target.value)}/>
        </div>
      </div>
      <div style={{background:C.white,borderRadius:10,border:`1px solid ${C.gray200}`,overflow:"hidden",marginBottom:14}}>
        <div style={{padding:"9px 14px",borderBottom:`1px solid ${C.gray100}`,fontWeight:600,fontSize:12}}>Prévia — 5 primeiras linhas</div>
        <div style={{overflowX:"auto"}}><table style={{width:"100%",borderCollapse:"collapse",fontSize:11}}>
          <thead><tr>{headers.slice(0,8).map((h,i)=><th key={i} style={TH}>{h||`C${i}`}</th>)}</tr></thead>
          <tbody>{rawRows.slice(0,5).map((r,i)=><tr key={i}>{r.slice(0,8).map((c,j)=><td key={j} style={{padding:"5px 10px",borderBottom:`1px solid ${C.gray100}`}}>{String(c||"").slice(0,18)}</td>)}</tr>)}</tbody>
        </table></div>
      </div>
      <div style={{display:"flex",gap:8,justifyContent:"flex-end"}}>
        <button style={btnS} onClick={()=>setStep("upload")}>← Voltar</button>
        <button style={btnP} onClick={buildPreview} disabled={!map.material||!map.qtd}>Processar →</button>
      </div>
    </div>}

    {step==="preview"&&<div>
      <div style={{display:"flex",gap:10,marginBottom:14}}>
        {[{v:preview.filter(p=>p.matched).length,l:"reconhecidos",bg:C.greenLight,co:C.green},{v:preview.filter(p=>!p.matched).length,l:"novos",bg:C.yellowLight,co:C.yellow},{v:preview.length,l:"total",bg:C.blueLight,co:C.blue}].map(k=><div key={k.l} style={{flex:1,background:k.bg,borderRadius:10,padding:12,textAlign:"center"}}>
          <div style={{fontSize:26,fontWeight:800,color:k.co}}>{k.v}</div>
          <div style={{fontSize:11,color:k.co}}>{k.l}</div>
        </div>)}
      </div>
      <div style={{background:C.white,borderRadius:10,border:`1px solid ${C.gray200}`,overflow:"hidden",marginBottom:12}}>
        <div style={{padding:"9px 14px",borderBottom:`1px solid ${C.gray100}`,fontWeight:600,fontSize:12}}>Registros a importar</div>
        <div style={{maxHeight:280,overflowY:"auto"}}><table style={{width:"100%",borderCollapse:"collapse",fontSize:12}}>
          <thead style={{position:"sticky",top:0}}><tr style={{background:C.gray50}}>
            {["SAP","Produto","Data","Qtd KG","Tipo","Status"].map(h=><th key={h} style={TH}>{h}</th>)}
          </tr></thead>
          <tbody>{preview.map((r,i)=><tr key={i} style={{borderBottom:`1px solid ${C.gray100}`,background:i%2===0?C.white:C.gray50}}>
            <td style={{padding:"5px 12px",fontFamily:"monospace",fontSize:10}}>{r.codeSAP}</td>
            <td style={{padding:"5px 12px",fontWeight:500}}>{r.nome}</td>
            <td style={{padding:"5px 12px"}}>{fmtDate(r.date)}</td>
            <td style={{padding:"5px 12px",fontWeight:700}}>{fmtN(r.qty)}</td>
            <td style={{padding:"5px 12px"}}>
              <span style={{background:r.type==="entrada"?C.greenLight:r.type==="saldo"?C.blueLight:C.redAlertLight,color:r.type==="entrada"?C.green:r.type==="saldo"?C.blue:C.redAlert,padding:"1px 7px",borderRadius:20,fontSize:10,fontWeight:700}}>
                {r.type==="entrada"?"↑ ENTRADA":r.type==="saldo"?"= SALDO":"↓ SAÍDA"}
              </span>
            </td>
            <td style={{padding:"5px 12px"}}>{r.matched?<span style={{color:C.green,fontSize:10,fontWeight:700}}>✓ OK</span>:<span style={{color:C.yellow,fontSize:10,fontWeight:700}}>⚡ Novo</span>}</td>
          </tr>)}</tbody>
        </table></div>
      </div>
      <div style={{display:"flex",gap:8,justifyContent:"flex-end"}}>
        <button style={btnS} onClick={()=>setStep("map")}>← Voltar</button>
        <button style={{...btnP,opacity:loading?0.7:1}} onClick={doImport} disabled={loading}>{loading?"Importando...":"✓ Confirmar"}</button>
      </div>
    </div>}

    {step==="done"&&result&&<div style={{textAlign:"center",padding:36}}>
      <div style={{fontSize:52,marginBottom:12}}>✅</div>
      <div style={{fontSize:20,fontWeight:800,marginBottom:4}}>Importação Concluída!</div>
      <div style={{color:C.gray400,marginBottom:20,fontSize:12}}>{fileName}</div>
      <div style={{display:"flex",gap:12,justifyContent:"center",marginBottom:24}}>
        <div style={{background:C.greenLight,borderRadius:12,padding:"14px 24px"}}><div style={{fontSize:28,fontWeight:800,color:C.green}}>{result.added}</div><div style={{fontSize:11,color:C.green}}>movimentos</div></div>
        {result.newProds>0&&<div style={{background:C.yellowLight,borderRadius:12,padding:"14px 24px"}}><div style={{fontSize:28,fontWeight:800,color:C.yellow}}>{result.newProds}</div><div style={{fontSize:11,color:C.yellow}}>novos produtos</div></div>}
      </div>
      <button style={btnS} onClick={()=>{setStep("upload");setPreview([]);setRawRows([]);setFileName("");}}>+ Importar outro</button>
    </div>}
  </div>;
}

/* ══════════════════════════════════════════════════
   APP PRINCIPAL
══════════════════════════════════════════════════ */
export default function App(){
  const[tab,setTab]=useState("Dashboard");
  const[products,setProducts]=useState(initialProducts);
  const[movements,setMovements]=useState(initialMovements);
  const[showAddProd,setShowAddProd]=useState(false);
  const[showAddMov,setShowAddMov]=useState(false);
  const[newProd,setNewProd]=useState({name:"",codeSAP:"",unit:"KG",type:"sólido",supplier:"",leadTime:15,criticality:"Média"});
  const[newMov,setNewMov]=useState({pid:"",date:new Date().toISOString().slice(0,10),tipo:"201",qty:"",dep:"BQ3",obs:""});
  const[logs,setLogs]=useState([{id:1,user:"sistema",action:"Dados SAP carregados — MB5B + MB51 · Jan–Mai 2026 · 14 produtos · 120 dias",date:"01/05/2026 00:00"}]);
  const[filterMov,setFilterMov]=useState("");
  const[prodDetails,setProdDetails]=useState(null);

  const addLog=a=>setLogs(l=>[{id:Date.now(),user:"operador",action:a,date:new Date().toLocaleString("pt-BR")},...l]);

  /* ══ ANALYTICS CORE ══
     Fórmula principal (conforme especificado):
     Consumo/dia = (EstIni + TotalEntradas - EstFin) / DiasDoPeríodo
               = TotalSaidas / DiasDoPeríodo   ← equivalente quando dados MB5B são consistentes
     
     Para produtos com histórico importado, recalcula a partir dos movimentos acumulados.
     Sempre usa o saldo SAP atual (estFin do produto) como estoque corrente.
  */
  const analytics = useMemo(()=>{
    return products.map(p=>{
      const movsProd = movements.filter(m=>m.pid===p.id).sort((a,b)=>a.date.localeCompare(b.date));

      // ── Consumo calculado a partir dos movimentos (tipos 201 e 261) ──
      const saidasMovs = movsProd.filter(m=>Number(m.qty)<0||(m.tipo==="201"||m.tipo==="261"));
      const entradasMovs = movsProd.filter(m=>Number(m.qty)>0&&(m.tipo==="101"||m.tipo==="311"||m.tipo==="202"));

      // Total saídas reais (consumo)
      const totalSaidasMovs = saidasMovs.reduce((s,m)=>s+Math.abs(Number(m.qty)),0);

      // Período real coberto pelos movimentos
      const datas = movsProd.map(m=>m.date).sort();
      const dIni = datas[0] ? new Date(datas[0]) : new Date("2026-01-01");
      const dFim = new Date("2026-05-01");
      const diasMovs = Math.max(1, Math.round((dFim-dIni)/(1000*60*60*24)));

      // Usar dados MB5B se produto original, ou movimentos se importado
      const isOriginal = initialProducts.some(ip=>ip.id===p.id);
      const totalSaidas = isOriginal ? p.totalSaidas : totalSaidasMovs;
      const totalEntradas = isOriginal ? p.totalEntradas : entradasMovs.reduce((s,m)=>s+Math.abs(Number(m.qty)),0);
      const dias = isOriginal ? PERIODO_DIAS : diasMovs;

      // ══ FÓRMULA CENTRAL (como solicitado) ══
      // Consumo = (EstIni + Entradas - EstFin) / Dias
      // = TotalSaidas / Dias  (matematicamente equivalente pelo balanço de massa)
      const consDia = totalSaidas > 0 ? totalSaidas / dias : 0;
      const consSem = consDia * 7;
      const consMes = consDia * 30;

      // Estoque atual (saldo SAP)
      const estAtual = isOriginal ? p.estFin : Math.max(0, p.estFin + entradasMovs.reduce((s,m)=>s+m.qty,0) - totalSaidasMovs);

      // Cobertura: dias que o estoque atual vai durar
      const cobertura = consDia > 0 ? Math.round(estAtual/consDia) : 9999;

      // Estoque mínimo = consumo de 60 dias
      const estMin = consDia * 60;

      // Ponto de pedido = consumo durante lead time
      const pontoPedido = consDia * p.leadTime;

      // Compra sugerida = cobrir 60 dias + lead time, menos estoque atual
      const compraSugerida = Math.max(0, consDia*(60+p.leadTime) - estAtual);

      // Consumo por mês (dos movimentos)
      const byMonth = {};
      saidasMovs.forEach(m=>{
        const mes=m.date.slice(0,7);
        byMonth[mes]=(byMonth[mes]||0)+Math.abs(Number(m.qty));
      });
      // Para produtos originais, complementar com dados MB5B mensais estimados
      if(isOriginal && Object.keys(byMonth).length === 0 && consDia > 0){
        MESES.forEach(mes=>{byMonth[mes]=Math.round(consMes);});
      }

      return {
        ...p, movsProd, totalSaidas, totalEntradas, dias,
        consDia, consSem, consMes, estAtual, cobertura,
        estMin, pontoPedido, compraSugerida, byMonth,
      };
    });
  },[products,movements]);

  const alerts = useMemo(()=>{
    const a=[];
    analytics.forEach(p=>{
      if(p.cobertura===0)a.push({sev:"critical",product:p.name,msg:"Estoque zerado — ruptura imediata",cod:p.codeSAP});
      else if(p.cobertura<30)a.push({sev:"critical",product:p.name,msg:`Cobertura crítica: ${p.cobertura} dias (< 30)`,cod:p.codeSAP});
      else if(p.cobertura<60)a.push({sev:"warning",product:p.name,msg:`Atenção: ${p.cobertura} dias de cobertura`,cod:p.codeSAP});
      if(p.estAtual>0&&p.estAtual<p.pontoPedido)a.push({sev:"warning",product:p.name,msg:`Abaixo do ponto de pedido (${fmtN(p.pontoPedido)} KG)`,cod:p.codeSAP});
    });
    return a.sort((a,b)=>(a.sev==="critical"?0:1)-(b.sev==="critical"?0:1));
  },[analytics]);

  const kpis = useMemo(()=>({
    total:analytics.length,
    critical:analytics.filter(p=>p.cobertura<30).length,
    attention:analytics.filter(p=>p.cobertura>=30&&p.cobertura<60).length,
    ok:analytics.filter(p=>p.cobertura>=60).length,
  }),[analytics]);

  function handleImport(newMovs,newProds,fileName){
    setMovements(m=>[...m,...newMovs]);
    if(newProds.length>0)setProducts(p=>[...p,...newProds]);
    addLog(`Importou ${newMovs.length} registros de ${fileName}${newProds.length>0?` · ${newProds.length} produtos novos`:""}`);
  }

  function handleAddProd(e){
    e.preventDefault();
    const p={...newProd,id:Date.now(),leadTime:Number(newProd.leadTime),estIni:0,totalEntradas:0,totalSaidas:0,estFin:0};
    setProducts(pr=>[...pr,p]);addLog(`Cadastrou ${p.codeSAP} – ${p.name}`);
    setNewProd({name:"",codeSAP:"",unit:"KG",type:"sólido",supplier:"",leadTime:15,criticality:"Média"});
    setShowAddProd(false);
  }

  function handleAddMov(e){
    e.preventDefault();
    const isConsume=newMov.tipo==="201"||newMov.tipo==="261";
    const m={...newMov,id:Date.now(),pid:Number(newMov.pid),qty:isConsume?-Math.abs(Number(newMov.qty)):Math.abs(Number(newMov.qty)),doc:"MANUAL"};
    setMovements(mv=>[...mv,m]);
    const pName=products.find(p=>p.id===m.pid)?.name??"";
    addLog(`${isConsume?"Saída":"Entrada"} manual: ${fmtN(Math.abs(m.qty))} KG – ${pName} · Tipo ${m.tipo}`);
    setNewMov({pid:"",date:new Date().toISOString().slice(0,10),tipo:"201",qty:"",dep:"BQ3",obs:""});
    setShowAddMov(false);
  }

  const filteredMovs=useMemo(()=>{
    const mv=[...movements].sort((a,b)=>b.date.localeCompare(a.date));
    if(!filterMov)return mv;
    const pIds=products.filter(p=>p.name.toLowerCase().includes(filterMov.toLowerCase())||p.codeSAP.includes(filterMov)).map(p=>p.id);
    return mv.filter(m=>pIds.includes(m.pid));
  },[movements,products,filterMov]);

  const maxStock=Math.max(...analytics.map(x=>x.estAtual),1);
  const maxSaidas=Math.max(...analytics.map(x=>x.totalSaidas),1);
  const maxConsDia=Math.max(...analytics.map(x=>x.consDia),1);

  return<div style={{minHeight:"100vh",background:C.gray50,fontFamily:"'IBM Plex Sans','Helvetica Neue',Arial,sans-serif",color:C.gray900}}>

    {/* HEADER */}
    <header style={{background:C.red,color:C.white,padding:"0 22px",display:"flex",alignItems:"center",gap:12,height:58,boxShadow:"0 2px 16px rgba(200,16,46,0.22)",position:"sticky",top:0,zIndex:100}}>
      <div style={{display:"flex",alignItems:"center",gap:9}}>
        <div style={{width:33,height:33,background:"rgba(255,255,255,0.15)",borderRadius:7,display:"flex",alignItems:"center",justifyContent:"center",fontSize:16,fontWeight:900}}>⬡</div>
        <div>
          <div style={{fontWeight:800,fontSize:14,letterSpacing:0.5}}>CHEMTRACK</div>
          <div style={{fontSize:9,opacity:0.72,letterSpacing:1.4,textTransform:"uppercase"}}>Refinaria de Manaus · C201</div>
        </div>
      </div>
      <div style={{flex:1}}/>
      <nav style={{display:"flex",gap:2}}>
        {TABS.map(t=><button key={t} onClick={()=>setTab(t)} style={{background:tab===t?"rgba(255,255,255,0.18)":"transparent",color:C.white,border:tab===t?"1.5px solid rgba(255,255,255,0.3)":"1.5px solid transparent",borderRadius:7,padding:"5px 11px",fontWeight:tab===t?700:500,fontSize:11,cursor:"pointer",fontFamily:"inherit",whiteSpace:"nowrap"}}>
          {t==="Importar SAP"?"📊 "+t:t}
        </button>)}
      </nav>
      {alerts.filter(a=>a.sev==="critical").length>0&&<div style={{background:"rgba(0,0,0,0.18)",borderRadius:7,padding:"4px 10px",fontSize:11,whiteSpace:"nowrap"}}>
        <span style={{background:C.white,color:C.red,borderRadius:20,padding:"1px 7px",fontWeight:800,marginRight:5}}>{alerts.filter(a=>a.sev==="critical").length}</span>críticos
      </div>}
    </header>

